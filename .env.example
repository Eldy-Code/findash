# ── Price data (optional fallbacks if yfinance fails) ─────────────────────────
# Finnhub — free at https://finnhub.io  (60 requests/min, no CC required)
# FINNHUB_API_KEY=your_finnhub_key

# Alpha Vantage — free at https://www.alphavantage.co  (25 req/day free)
# ALPHAVANTAGE_API_KEY=your_alphavantage_key

# ── Reddit API credentials (required for Reddit scanning) ─────────────────────
# Get free credentials at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=FinDash/1.0 by your_username

# Plaid credentials (optional - for future automated Fidelity sync)
# PLAID_CLIENT_ID=your_plaid_client_id
# PLAID_SECRET=your_plaid_secret
# PLAID_ENV=sandbox

# Database (defaults to local SQLite)
# DATABASE_URL=sqlite:///./findash.db

# Port to run on (default: 8000)
# PORT=8000
